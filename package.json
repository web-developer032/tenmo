    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.11.0",
    "nanoid": "5.1.9",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "pdfkit": "^0.18.0",
    "pino": "10.3.1",
    "posthog-js": "^1.372.3",
    "posthog-node": "^5.30.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.74.0",
    "sonner": "2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
