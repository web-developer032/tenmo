    "@testing-library/user-event": "14.6.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.6.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.0.2",
    "lodash-es": "4.18.1",
    "msw": "2.13.6",
    "pino-pretty": "13.1.3",
