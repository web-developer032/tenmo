{
  "name": "@tenantly/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:next": "eslint .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:types": "node scripts/gen-db-types.mjs",
    "db:reset": "cd ../backend && npx supabase db reset",
    "db:diff": "cd ../backend && npx supabase db diff -f"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
