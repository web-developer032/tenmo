# Tenantly web — local environment template
# Copy to `.env.local` and fill in real values for your local dev.

# ============================================================================
# Public (exposed to the browser)
# ============================================================================

# Supabase project URL and anon key (safe for client)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=__local_anon_key__

# Site URL — used for OAuth redirects + emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public PostHog config (optional in dev). When NEXT_PUBLIC_POSTHOG_KEY is
# unset, the browser SDK + posthog-node singleton both no-op gracefully and
# the `trackServer()` helper falls back to logging to Pino. Default host is
# the EU cluster — override for US tenancy.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Public Sentry DSN (optional in dev). Drives the runtime SDK across browser,
# Node, and Edge runtimes. Without it the @sentry/nextjs init short-circuits
# and `captureError()` is a no-op.
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# Server-only (NEVER prefix with NEXT_PUBLIC_)
# ============================================================================

# Supabase service role key — server-only, used by webhook + Inngest handlers
SUPABASE_SERVICE_ROLE_KEY=__local_service_role_key__

# Resend (email) — leave RESEND_API_KEY empty in dev to log emails to console
RESEND_API_KEY=
RESEND_FROM_EMAIL=Tenantly <noreply@tenantly.app>

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe (landlord subscriptions only — never billed to tenants)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Per-tier Stripe Price IDs (one per tier × interval). Optional in dev;
# the /api/billing/checkout route returns 503 with a clear message if
# the requested tier+interval has no configured price id.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_PORTFOLIO_MONTHLY=
STRIPE_PRICE_PORTFOLIO_ANNUAL=

# GoCardless (tenant rent — fees absorbed by landlord/platform)
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_WEBHOOK_SECRET=

# TrueLayer (Open Banking — v1.1)
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_WEBHOOK_SECRET=

# Twilio (SMS / WhatsApp — v1.1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# DocuSeal (e-signatures — self-hosted at the URL above; HMAC-SHA256
# webhook secret should match the value set in DocuSeal admin).
DOCUSEAL_API_URL=http://localhost:3030
DOCUSEAL_API_TOKEN=
DOCUSEAL_WEBHOOK_SECRET=
# Template id for the AST template uploaded into your DocuSeal instance.
DOCUSEAL_AST_TEMPLATE_ID=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry build-time sourcemap upload. All three must be set for
# next.config.ts to wrap the build with `withSentryConfig` — typically only
# needed in CI / production builds. Local dev works fine without them.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Cron — shared secret for /api/cron/* routes. Vercel Cron sends this as
# `Authorization: Bearer <CRON_SECRET>`. Generate with `openssl rand -hex 32`.
# If empty, cron routes accept localhost-only requests for local dev.
CRON_SECRET=

# Logging level: 'trace' | 'debug' | 'info' | 'warn' | 'error' | 'fatal'
LOG_LEVEL=debug
